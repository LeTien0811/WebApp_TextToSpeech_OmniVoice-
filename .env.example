# API Key để bảo vệ endpoint /synthesize
# Để trống → không cần auth (dev mode)
TTS_API_KEY=your-secret-api-key-here

# Đường dẫn đến file audio mẫu giọng (WAV, 16kHz mono khuyến nghị)
TTS_REF_AUDIO=./voice_sample.wav

# Text tương ứng với file audio mẫu (dùng để encode voice prompt)
TTS_REF_TEXT=Xin chào! Tôi là nhân viên hỗ trợ thủ tục hành chính. Tôi có thể giúp gì cho bạn hôm nay?
